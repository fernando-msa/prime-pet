{
  "rules": {
    ".read": false,
    ".write": false,

    "agendamentos": {
      ".read": "auth != null && (auth.token.admin === true || auth.token.email === 'ribeirojunior270@gmail.com' || auth.token.email === 'arthurleite71@gmail.com')",
      "$date": {
        "$hour": {
          ".write": "auth != null && (auth.token.admin === true || auth.token.email === 'ribeirojunior270@gmail.com' || auth.token.email === 'arthurleite71@gmail.com')"
        }
      }
    },

    "historico_acoes": {
      ".read": "auth != null && (auth.token.admin === true || auth.token.email === 'ribeirojunior270@gmail.com' || auth.token.email === 'arthurleite71@gmail.com')",
      ".write": "auth != null && (auth.token.admin === true || auth.token.email === 'ribeirojunior270@gmail.com' || auth.token.email === 'arthurleite71@gmail.com')"
    },

    "logs_erros": {
      ".read": "auth != null && (auth.token.admin === true || auth.token.email === 'ribeirojunior270@gmail.com' || auth.token.email === 'arthurleite71@gmail.com')",
      "$logId": {
        ".write": "auth != null",
        "contexto": { ".validate": "newData.isString() && newData.val().length <= 80" },
        "code": { ".validate": "newData.isString() && newData.val().length <= 120" },
        "message": { ".validate": "newData.isString() && newData.val().length <= 500" },
        "path": { ".validate": "newData.isString() && newData.val().length <= 200" },
        "email": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 160)" },
        "userAgent": { ".validate": "newData.isString() && newData.val().length <= 400" },
        "at": { ".validate": "newData.isNumber()" }
      }
    },

    "historico_clientes": {
      ".indexOn": ["ownerUid"],
      ".read": "auth != null && ((query.orderByChild === 'ownerUid' && query.equalTo === auth.uid) || auth.token.admin === true || auth.token.email === 'ribeirojunior270@gmail.com' || auth.token.email === 'arthurleite71@gmail.com')",

      "$id": {
        ".read": "auth != null && (auth.token.admin === true || data.child('ownerUid').val() === auth.uid)",
        ".write": "(auth != null && (auth.token.admin === true || auth.token.email === 'ribeirojunior270@gmail.com' || auth.token.email === 'arthurleite71@gmail.com')) || (auth != null && ((data.exists() && data.child('ownerUid').val() === auth.uid) || (!data.exists() && newData.child('ownerUid').val() === auth.uid)))",

        "ownerUid": {
          ".validate": "newData.isString() && (auth.token.admin === true || auth.token.email === 'ribeirojunior270@gmail.com' || auth.token.email === 'arthurleite71@gmail.com' || newData.val() === auth.uid)"
        },

        "telefone": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^[0-9()+\\-\\s]{10,20}$/))"
        },

        "mapsLink": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^https:\\/\\/.+/))"
        },

        "status": {
          ".validate": "!newData.exists() || (newData.isString() && (newData.val() === 'pending' || newData.val() === 'confirmed' || newData.val() === 'cancelled'))"
        }
      }
    },

    "clientes_perfis": {
      "$uid": {
        ".read": "auth != null && (auth.token.admin === true || auth.token.email === 'ribeirojunior270@gmail.com' || auth.token.email === 'arthurleite71@gmail.com' || auth.uid === $uid)",
        ".write": "auth != null && (auth.token.admin === true || auth.token.email === 'ribeirojunior270@gmail.com' || auth.token.email === 'arthurleite71@gmail.com' || auth.uid === $uid)"
      }
    },

    "public_config": {
      "maintenance": {
        ".read": true,
        ".write": "auth != null && (auth.token.admin === true || auth.token.email === 'ribeirojunior270@gmail.com' || auth.token.email === 'arthurleite71@gmail.com')"
      }
    }
  }
}
