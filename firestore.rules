rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /admin_users/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow write: if isAdmin();
    }

    match /maintenance/config {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.ownerUid == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.status in ['pending', 'confirmed', 'cancelled'];

      allow update: if isAdmin()
        || (isSignedIn()
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.status in ['pending', 'confirmed', 'cancelled']);

      allow delete: if isAdmin();
    }

    match /profiles/{uid} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    match /assistant_faq/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /assistant_questions/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /metrics_daily/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /vaccine_alerts/{alertId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }
  }
}
