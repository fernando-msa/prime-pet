rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true
        || (
          exists(/databases/$(database)/documents/admin_users/$(request.auth.uid))
          && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.enabled != false
        )
      );
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /admin_users/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow write: if isAdmin();
    }

    function validStatus(status) {
      return status in ['pending', 'confirmed', 'cancelled'];
    }

    // ── Coleções novas (modelo Firestore nativo) ───────────────────────────
    match /maintenance/config {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ops_config/{docId} {
      allow read, write: if false;
    }

    match /appointments/{appointmentId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.ownerUid == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && validStatus(request.resource.data.status);

      allow update: if isAdmin()
        || (isSignedIn()
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid
          && validStatus(request.resource.data.status));

      allow delete: if isAdmin();
    }

    match /profiles/{uid} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    match /assistant_faq/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /assistant_questions/{docId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /metrics_daily/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /vaccine_alerts/{alertId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ── Coleções legadas usadas pela camada de compatibilidade ─────────────
    match /agendamentos/{id} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && validStatus(request.resource.data.status);
      allow delete: if isSignedIn();
    }

    match /historico_acoes/{id} {
      allow read, write: if isAdmin();
    }

    match /logs_erros/{id} {
      allow read: if isAdmin();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /historico_clientes/{id} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.ownerUid == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAdmin()
        || (isSignedIn()
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /clientes_perfis/{uid} {
      allow read, write: if isAdmin() || isSelf(uid);
    }

    match /public_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /assistente_faq/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /assistente_duvidas/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
